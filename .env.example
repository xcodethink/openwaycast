# WayCast 配置示例 —— 复制为 .env(或直接 export)。全部可选:不设任何 key,本地链路也能跑。
# 加载方式:大多数 shell 用 `set -a; source .env; set +a`,或在命令前 `KEY=val ...`。
# .env 已被 .gitignore 忽略,别提交真实 key。

# ── LLM(内容文案;不设则走确定性启发式/骨架)──────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# WAYCAST_LLM_PROVIDER=anthropic        # anthropic | openai(默认:有哪个 key 用哪个)
# WAYCAST_LLM_MODEL=claude-sonnet-4-6   # 覆盖默认模型(openai 默认 gpt-4o-mini)

# ── 图库选图(自动配城市/商务背景;不设则用 --reuse-bg 或手动放图)──────────
# PEXELS_API_KEY=...                     # https://www.pexels.com/api/(免费)
# UNSPLASH_ACCESS_KEY=...                # https://unsplash.com/developers(免费)
# WAYCAST_IMAGE_PROVIDER=pexels          # pexels | unsplash(默认:有哪个 key 用哪个)

# ── TTS 配音(默认本地:zh→CosyVoice / 其余→Kokoro;切云需对应 key)─────────
# WAYCAST_TTS_PROVIDER=kokoro            # kokoro | cosyvoice | openai | elevenlabs | azure
# WAYCAST_TTS_VOICE=onyx                 # 覆盖音色(各 provider 含义不同)
# WAYCAST_TTS_MODEL=tts-1               # 覆盖云 TTS 模型
# VO_VOICE=am_michael                    # Kokoro 音色
#   云 TTS key:
# OPENAI_API_KEY=sk-...                  # provider=openai 复用(/v1/audio/speech)
# ELEVENLABS_API_KEY=...                 # provider=elevenlabs
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# AZURE_TTS_KEY=...                      # provider=azure
# AZURE_TTS_REGION=eastus

# ── 本地工具/模型路径(默认自动探测,换机器或非标准位置才需设)───────────────
# FFMPEG=/opt/homebrew/bin/ffmpeg
# FFPROBE=/opt/homebrew/bin/ffprobe
# KOKORO_VENV=~/.hyperframes-tts-venv
# COSYVOICE_PY=~/miniforge3/envs/cosyvoice/bin/python
# COSYVOICE_REPO=~/CosyVoice          # 本地 CosyVoice 克隆路径(默认 ~/CosyVoice;放别处就设这个)

# ── 出片 ──────────────────────────────────────────────────────────────────
# OUTPUT_DIR=./output                    # 成片输出目录(默认 engine/../output)
